{
  "name": "april-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "AI Desktop Agent",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @april/desktop",
    "build": "npm run build -w @april/core && npm run build -w @april/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "start": "npm run start -w @april/desktop",
    "build:mac": "npm run build:mac -w @april/desktop",
    "build:win": "npm run build:win -w @april/desktop",
    "build:linux": "npm run build:linux -w @april/desktop",
    "deploy:mac": "npm run deploy:mac -w @april/desktop",
    "postinstall:desktop": "npm run postinstall -w @april/desktop",
    "clear-state": "rm -rf \"$HOME/Library/Application Support/april-agent-dev\""
  }
}
